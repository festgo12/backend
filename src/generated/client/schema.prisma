generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  FROZEN
  SUSPENDED
}

enum Currency {
  NGN
  USDT
  BTC
  ETH
  USDC
}

enum LedgerType {
  DEPOSIT
  WITHDRAWAL
  TRADE_RESERVE
  TRADE_SETTLEMENT
  TRADE_REFUND
  FEE
  GIFT_CARD_PURCHASE
  GIFT_CARD_SALE
}

enum OrderStatus {
  CREATED
  PENDING_SELLER
  APPROVED
  COMPLETED
  DECLINED
  EXPIRED
  CANCELLED
  DISPUTED
}

enum AdType {
  BUY
  SELL
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  WAITING_FOR_USER
  WAITING_FOR_ADMIN
  RESOLVED
  REJECTED
  ESCALATED
}

model User {
  id                       String             @id @default(uuid()) @db.Uuid
  email                    String?            @unique
  phone                    String?            @unique
  passwordHash             String
  role                     Role               @default(USER)
  status                   UserStatus         @default(ACTIVE)
  profile                  Profile?
  preferences              UserPreference?
  wallets                  Wallet[]
  ads                      Ad[]
  buyOrders                Order[]            @relation("BuyerOrders")
  sellOrders               Order[]            @relation("SellerOrders")
  authTokens               AuthToken[]
  devices                  Device[]
  notifications            Notification[]
  notificationLogs         NotificationLog[]
  initiatedDisputes        Dispute[]          @relation("Initiator")
  assignedDisputes         Dispute[]          @relation("Assignee")
  evidenceUploads          Evidence[]
  giftCardListings         GiftCardListing[]
  moderatedListings        GiftCardListing[]  @relation("ModeratedListings")
  giftCardBuyerOrders      GiftCardOrder[]    @relation("GiftCardBuyerOrders")
  giftCardSellerOrders     GiftCardOrder[]    @relation("GiftCardSellerOrders")
  giftCardEvidence         GiftCardEvidence[]
  securityLogs             SecurityLog[]
  securityAlerts           SecurityAlert[]
  twoFactorEnabled         Boolean            @default(false)
  twoFactorSecret          String?
  resetToken               String?            @unique
  resetTokenExpires        DateTime?
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  emailVerified            Boolean            @default(false)
  phoneVerificationToken   String?
  phoneVerificationExpires DateTime?
  phoneVerified            Boolean            @default(false)
  failedLoginAttempts      Int                @default(0)
  lockedUntil              DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([email, phone])
}

model Profile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  firstName String?
  lastName  String?
  kycStatus String   @default("NONE")
  avatarUrl String?
  updatedAt DateTime @updatedAt
}

model UserPreference {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  baseCurrency String   @default("NGN")
  emailNotify  Boolean  @default(true)
  pushNotify   Boolean  @default(true)
  theme        String   @default("DARK")
  updatedAt    DateTime @updatedAt
}

model Wallet {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @db.Uuid
  user            User                @relation(fields: [userId], references: [id])
  currency        Currency
  balance         Decimal             @default(0) @db.Decimal(20, 8)
  reservedBalance Decimal             @default(0) @db.Decimal(20, 8)
  address         String?             @unique
  ledgerEntries   LedgerEntry[]
  transactions    WalletTransaction[]
  snapshots       BalanceSnapshot[]
  updatedAt       DateTime            @updatedAt
  version         Int                 @default(0)

  @@unique([userId, currency])
  @@index([userId])
}

model LedgerEntry {
  id            String             @id @default(uuid()) @db.Uuid
  walletId      String             @db.Uuid
  wallet        Wallet             @relation(fields: [walletId], references: [id])
  transactionId String?            @db.Uuid
  transaction   WalletTransaction? @relation(fields: [transactionId], references: [id])
  orderId       String?            @db.Uuid
  order         Order?             @relation(fields: [orderId], references: [id])
  amount        Decimal            @db.Decimal(20, 8)
  type          LedgerType
  reference     String             @unique
  balanceAfter  Decimal            @db.Decimal(20, 8)
  metadata      Json?
  createdAt     DateTime           @default(now())

  @@index([walletId])
  @@index([orderId])
  @@index([transactionId])
}

model WalletTransaction {
  id            String        @id @default(uuid()) @db.Uuid
  walletId      String        @db.Uuid
  wallet        Wallet        @relation(fields: [walletId], references: [id])
  type          LedgerType
  status        String        @default("PENDING")
  amount        Decimal       @db.Decimal(20, 8)
  fee           Decimal       @default(0) @db.Decimal(20, 8)
  reference     String        @unique
  metadata      Json?
  ledgerEntries LedgerEntry[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([walletId, status])
}

model BalanceSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  walletId  String   @db.Uuid
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  balance   Decimal  @db.Decimal(20, 8)
  ledgerId  String?  @db.Uuid
  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
}

model Ad {
  id          String   @id @default(uuid()) @db.Uuid
  sellerId    String   @db.Uuid
  seller      User     @relation(fields: [sellerId], references: [id])
  asset       Currency
  type        AdType
  price       Decimal  @db.Decimal(20, 8)
  quantity    Decimal  @db.Decimal(20, 8)
  minLimit    Decimal  @db.Decimal(20, 8)
  maxLimit    Decimal  @db.Decimal(20, 8)
  isSponsored Boolean  @default(false)
  status      String   @default("ACTIVE")
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version     Int      @default(0)

  @@index([sellerId, asset, type])
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  adId          String        @db.Uuid
  ad            Ad            @relation(fields: [adId], references: [id])
  buyerId       String        @db.Uuid
  buyer         User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId      String        @db.Uuid
  seller        User          @relation("SellerOrders", fields: [sellerId], references: [id])
  status        OrderStatus   @default(CREATED)
  fiatAmount    Decimal       @db.Decimal(20, 2)
  cryptoAmount  Decimal       @db.Decimal(20, 8)
  feeAmount     Decimal       @db.Decimal(20, 8)
  ledgerEntries LedgerEntry[]
  disputes      Dispute[]
  expiresAt     DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  version       Int           @default(0)
  fraudFlagged  Boolean       @default(false)

  @@index([buyerId, sellerId, status])
}

model Dispute {
  id          String        @id @default(uuid()) @db.Uuid
  orderId     String        @db.Uuid
  order       Order         @relation(fields: [orderId], references: [id])
  initiatorId String        @db.Uuid
  initiator   User          @relation("Initiator", fields: [initiatorId], references: [id])
  reason      String        @db.Text
  description String?       @db.Text
  status      DisputeStatus @default(OPEN)
  assigneeId  String?       @db.Uuid
  assignee    User?         @relation("Assignee", fields: [assigneeId], references: [id])
  resolution  String?       @db.Text
  deadline    DateTime?
  evidence    Evidence[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orderId])
  @@index([initiatorId])
  @@index([assigneeId])
  @@index([status])
}

model Evidence {
  id           String   @id @default(uuid()) @db.Uuid
  disputeId    String   @db.Uuid
  dispute      Dispute  @relation(fields: [disputeId], references: [id])
  url          String
  fileName     String
  fileType     String
  fileSize     Int
  uploadedById String   @db.Uuid
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([disputeId])
}

model AuthToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id])
  token        String    @unique
  expiresAt    DateTime
  userAgent    String?
  ipAddress    String?
  lastActivity DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Device {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id])
  deviceId     String
  fingerprint  String
  deviceName   String?
  browser      String?
  osVersion    String?
  location     String?
  ipAddress    String?
  userAgent    String?
  fcmToken     String?
  lastLogin    DateTime  @default(now())
  lastActivity DateTime?
  createdAt    DateTime  @default(now())

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([fingerprint])
}

model SecurityLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  actorId      String?  @db.Uuid
  action       String
  resource     String?
  resourceId   String?
  oldValue     Json?
  newValue     Json?
  metadata     Json?
  ipAddress    String?
  device       String?
  success      Boolean  @default(true)
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([userId, action])
  @@index([action, createdAt])
  @@index([resource, resourceId])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

model NotificationTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  type         String   @unique
  name         String
  emailSubject String?
  emailBody    String?  @db.Text
  pushTitle    String?
  pushBody     String?  @db.Text
  inAppTitle   String
  inAppBody    String   @db.Text
  smsBody      String?  @db.Text
  systemBody   String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NotificationLog {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @db.Uuid
  user         User                @relation(fields: [userId], references: [id])
  type         String
  channel      NotificationChannel
  recipient    String
  title        String
  body         String
  status       NotificationStatus  @default(PENDING)
  retryCount   Int                 @default(0)
  maxRetries   Int                 @default(3)
  nextTryAt    DateTime?
  errorDetails String?             @db.Text
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([userId])
  @@index([status, nextTryAt])
}

model SecurityAlert {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  severity  String   @default("MEDIUM")
  title     String
  message   String   @db.Text
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model FraudRule {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  code        String   @unique
  description String   @db.Text
  enabled     Boolean  @default(true)
  threshold   Int      @default(5)
  severity    String   @default("MEDIUM")
  action      String   @default("ALERT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum GiftCardBrand {
  AMAZON
  APPLE
  STEAM
  GOOGLE_PLAY
  VISA_GIFT
  MASTERCARD_GIFT
  OTHER
}

enum GiftCardListingStatus {
  PENDING_REVIEW
  ACTIVE
  SOLD
  EXPIRED
  REJECTED
  PAUSED
}

enum GiftCardOrderStatus {
  CREATED
  PENDING_DELIVERY
  COMPLETED
  CANCELLED
  DISPUTED
}

model GiftCardListing {
  id              String                @id @default(uuid()) @db.Uuid
  sellerId        String                @db.Uuid
  seller          User                  @relation(fields: [sellerId], references: [id])
  brand           GiftCardBrand
  cardCode        String
  cardPin         String?
  denomination    Decimal               @db.Decimal(10, 2)
  cardCurrency    String
  exchangeRate    Decimal               @db.Decimal(12, 2)
  askingPriceNgn  Decimal               @db.Decimal(12, 2)
  status          GiftCardListingStatus @default(PENDING_REVIEW)
  evidenceUrls    Json?
  moderatorId     String?               @db.Uuid
  moderator       User?                 @relation("ModeratedListings", fields: [moderatorId], references: [id])
  moderatorNote   String?
  orders          GiftCardOrder[]
  evidenceRecords GiftCardEvidence[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  version         Int                   @default(0)

  @@index([sellerId])
  @@index([status])
  @@index([brand, status])
}

model GiftCardOrder {
  id             String              @id @default(uuid()) @db.Uuid
  listingId      String              @db.Uuid
  listing        GiftCardListing     @relation(fields: [listingId], references: [id])
  buyerId        String              @db.Uuid
  buyer          User                @relation("GiftCardBuyerOrders", fields: [buyerId], references: [id])
  sellerId       String              @db.Uuid
  seller         User                @relation("GiftCardSellerOrders", fields: [sellerId], references: [id])
  status         GiftCardOrderStatus @default(CREATED)
  denomination   Decimal             @db.Decimal(10, 2)
  cardCurrency   String
  askingPriceNgn Decimal             @db.Decimal(12, 2)
  feeAmount      Decimal             @default(0) @db.Decimal(12, 2)
  totalPaidNgn   Decimal             @db.Decimal(12, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  version        Int                 @default(0)

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model GiftCardEvidence {
  id         String          @id @default(uuid()) @db.Uuid
  listingId  String          @db.Uuid
  listing    GiftCardListing @relation(fields: [listingId], references: [id])
  uploadedBy String          @db.Uuid
  uploader   User            @relation(fields: [uploadedBy], references: [id])
  fileUrl    String
  fileType   String
  createdAt  DateTime        @default(now())

  @@index([listingId])
}

model PlatformFeeConfig {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Decimal  @db.Decimal(10, 4)
  label     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model DailyReport {
  id                String   @id @default(uuid()) @db.Uuid
  date              DateTime @unique
  platformFeesNgn   Decimal  @default(0) @db.Decimal(16, 2)
  tradingVolumeNgn  Decimal  @default(0) @db.Decimal(16, 2)
  tradingVolumeUsd  Decimal  @default(0) @db.Decimal(16, 2)
  totalOrders       Int      @default(0)
  completedOrders   Int      @default(0)
  cancelledOrders   Int      @default(0)
  depositsNgn       Decimal  @default(0) @db.Decimal(16, 2)
  depositCount      Int      @default(0)
  withdrawalsNgn    Decimal  @default(0) @db.Decimal(16, 2)
  withdrawalCount   Int      @default(0)
  giftCardVolumeNgn Decimal  @default(0) @db.Decimal(16, 2)
  giftCardCount     Int      @default(0)
  newUsers          Int      @default(0)
  totalUsers        Int      @default(0)
  newDisputes       Int      @default(0)
  resolvedDisputes  Int      @default(0)
  fraudEvents       Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([date])
}

model HelpContent {
  id        String   @id @default(uuid())
  category  String
  title     String
  content   String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}
